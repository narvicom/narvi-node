{
  "name": "narvi",
  "version": "2.0.51",
  "description": "Narvi API wrapper",
  "keywords": [
    "narvi",
    "payment processing",
    "api"
  ],
  "homepage": "https://github.com/narvicom/narvi-node",
  "author": "Narvi <support@narvi.com> (https://narvi.com/)",
  "contributors": [
    "K. Kuchta <k.kuchta@narvi.com>",
    "L. Rutkowski <l.rutkowski@narvi.com>",
    "D. Drozd <d.drozd@narvi.com>"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/narvicom/narvi-node.git"
  },
  "bugs": {
    "url": "https://github.com/narvicom/narvi-node/issues"
  },
  "engines": {
    "node": ">=12.0.0"
  },
  "main": "cjs/narvi.cjs.node.js",
  "types": "types/index.d.ts",
  "files": [
    "cjs",
    "esm",
    "types"
  ],
  "devDependencies": {
    "@release-it/conventional-changelog": "11.0.0",
    "@types/node": "25.7.0",
    "@types/qs": "6.15.1",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "eslint": "10.3.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "genversion": "3.2.0",
    "release-it": "20.0.1",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  },
  "resolutions": {
    "minimist": "1.2.8",
    "nanoid": "5.1.11",
    "basic-ftp": ">=5.2.0",
    "handlebars": ">=4.7.9",
    "minimatch": ">=3.1.4",
    "flatted": ">=3.4.2",
    "diff": ">=4.0.4"
  },
  "dependencies": {
    "events": "^3.3.0",
    "json-stable-stringify": "^1.3.0",
    "lodash.isempty": "^4.4.0",
    "qs": "^6.15.1",
    "ramda": "^0.32.0"
  },
  "sideEffects": false,
  "license": "MIT",
  "scripts": {
    "build": "yarn build-esm && yarn build-cjs",
    "build-esm": "mkdir -p esm && tsc -p tsconfig.esm.json && echo '{\"type\":\"module\"}' > esm/package.json",
    "build-cjs": "mkdir -p cjs && tsc -p tsconfig.cjs.json && echo '{\"type\":\"commonjs\"}' > cjs/package.json",
    "prepack": "yarn install && yarn build",
    "r": "release-it --ci",
    "rc": "release-it --ci --dry-run",
    "publish": "npm publish --access public"
  },
  "exports": {
    "types": "./types/index.d.ts",
    "default": {
      "import": "./esm/narvi.esm.node.js",
      "require": "./cjs/narvi.cjs.node.js"
    }
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
