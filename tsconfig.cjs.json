{
  "compilerOptions": {
    "outDir": "./cjs",
    "rootDir": "./src",
    "module": "commonjs",
    "target": "es2017",
    "checkJs": false,
    "alwaysStrict": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "strict": true,
    "strictFunctionTypes": true,
    "types": [
      "node"
    ],
    "esModuleInterop": false,
    // This is a viral option, do not enable https://www.semver-ts.org/#module-interop
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "./src/**/*"
  ],
  "exclude": [
    "./src/narvi.esm.node.ts"
  ]
}
